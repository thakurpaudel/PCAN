# Enable USB OTG and TinyUSB
CONFIG_USB_OTG_SUPPORTED=y
CONFIG_TINYUSB=y
CONFIG_TINYUSB_HID_COUNT=1
CONFIG_TINYUSB_CDC_COUNT=0
CONFIG_TINYUSB_MSC_COUNT=0
CONFIG_TINYUSB_MIDI_COUNT=0

# Configure USB OTG peripheral
CONFIG_USB_HOST_CONTROL_WORKERS=
CONFIG_USB_OTG_PERIPHERAL=y

# TWAI Configuration
CONFIG_TWAI_ISR_IN_IRAM=y
CONFIG_PCAN_USB_LINK_LED_PIN=8
CONFIG_PCAN_CAN_ACTIVITY_LED_PIN=9
# CONFIG_PCAN_LED_ACTIVE_LOW is not set

# FreeRTOS config for faster response
CONFIG_FREERTOS_HZ=1000

# Compiler options
CONFIG_COMPILER_OPTIMIZATION_PERF=y
